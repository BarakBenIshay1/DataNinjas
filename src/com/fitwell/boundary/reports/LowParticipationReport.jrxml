<jasperReport name="LowParticipationReport" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="875911e2-b42d-4374-bb76-1171789fa176">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="FitWell_Access_DB"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<parameter name="fromDate" class="java.sql.Date"/>
	<parameter name="toDate" class="java.sql.Date"/>
	<query language="sql"><![CDATA[SELECT
    t.traineeId,
    t.firstName,
    t.lastName,
    t.phoneNumber,
    t.email,
    COUNT(cr.classID) AS trainingCount
FROM
    (TRAINEE t
     LEFT JOIN ClassRegistration cr
        ON t.traineeId = cr.traineeId)
     LEFT JOIN TrainingClass tc
        ON cr.classID = tc.classID
WHERE
    tc.startTime BETWEEN $P{fromDate} AND $P{toDate}
GROUP BY
    t.traineeId,
    t.firstName,
    t.lastName,
    t.phoneNumber,
    t.email
HAVING
    COUNT(cr.classID) < 7
ORDER BY
    trainingCount ASC;
]]></query>
